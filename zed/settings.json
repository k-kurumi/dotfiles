// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "icon_theme": {
    "mode": "light",
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Mocha",
  },
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "auto_update": false,
  "proxy": "",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Gruvbox Dark Hard",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "ui_font_size": 18,
  "cursor_blink": false,
  "buffer_font_family": "UDEV Gothic NF",
  "buffer_font_size": 20,
  // 100から900で指定する 900が太い
  "buffer_font_weight": 600,
  "soft_wrap": "none",

  // 追加する拡張機能名は ~/Library/Application Support/Zed/extensions/installed で確認する
  // zedコマンドから取得不可らしい
  "auto_install_extensions": {
    "catppuccin-icons": true,
  },
}
